{
  "name": "switchboard",
  "version": "0.6.3",
  "description": "A switchboard for your Claude Code and Codex conversations — browse, preview, resume, and start sessions.",
  "main": "./out/main/index.js",
  "author": "Adam Gordon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adambgordon/switchboard.git"
  },
  "homepage": "https://github.com/adambgordon/switchboard#readme",
  "bugs": "https://github.com/adambgordon/switchboard/issues",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "rebuild": "node scripts/rebuild-native.mjs",
    "package": "electron-vite build && electron-builder --dir",
    "setup": "node scripts/setup.mjs"
  },
  "dependencies": {
    "@fontsource/hanken-grotesk": "latest",
    "@fontsource/ibm-plex-mono": "latest",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "chokidar": "^3.6.0",
    "fuse.js": "^7.0.0",
    "highlight.js": "^11.11.1",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "latest",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "build": {
    "appId": "dev.adamgordon.switchboard",
    "productName": "Switchboard",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "build/icon-dark.png",
        "to": "icon-dark.png"
      }
    ],
    "mac": {
      "target": "dir",
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns"
    }
  }
}
